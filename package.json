{
  "name": "@klaut-pro/klaut-liquid-glass",
  "version": "0.1.0",
  "description": "From-scratch WebGL2 liquid glass: live-DOM glassify, liquify/drops, thin-film fringe",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "bake:glyphs": "node scripts/run-bake-glyphs.mjs",
    "bake:glyphs:edt": "python scripts/bake-glyph-sdf.py",
    "bake:env": "python scripts/bake-concept-env.py",
    "bake:faces": "python scripts/bake-concept-faceplates.py",
    "bake:scratch": "node scripts/run-bake-scratch.mjs",
    "capture:glyph-qa": "node scripts/capture-glyph-qa.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "demo:serve": "npx --yes serve -l 52780 ."
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.61.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/klaut-pro/klaut-liquid-glass.git"
  },
  "keywords": [
    "webgl",
    "liquid-glass",
    "refraction",
    "metaballs",
    "thin-film",
    "klaut"
  ],
  "engines": {
    "node": ">=18"
  }
}
